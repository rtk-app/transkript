{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://ais-pre-2lpflfbgv3zguc7cmukegn-95100727405.europe-west3.run.app/",
      "permanent": false
    }
  ],
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
