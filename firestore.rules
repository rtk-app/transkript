rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transcriptions
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - The user ID of the owner.
    //   - originalText: string (required) - The original transcribed text.
    //   - translatedText: string (optional) - The translated text.
    //   - targetLanguage: string (optional) - The language the text was translated to.
    //   - createdAt: timestamp (required, immutable) - When the transcription was saved.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidTranscription(data) {
      return hasOnlyAllowedFields(['uid', 'originalText', 'translatedText', 'targetLanguage', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.originalText is string && data.originalText.size() <= 100000 &&
             (!('translatedText' in data) || (data.translatedText is string && data.translatedText.size() <= 100000)) &&
             (!('targetLanguage' in data) || (data.targetLanguage is string && data.targetLanguage.size() <= 50)) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transcriptions/{transcriptionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                    isValidTranscription(request.resource.data) && 
                    uidUnchanged() &&
                    request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && 
                    isValidTranscription(request.resource.data) && 
                    uidNotModified() &&
                    areImmutableFieldsUnchanged(['uid', 'createdAt']);
      allow delete: if isDocOwner();
    }
  }
}
